{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install donut-ls",
      "type": "shell",
      "command": "cargo install --path .",
      "options": {
        "cwd": "${workspaceFolder}/donut-ls"
      },
      "problemMatcher": []
    },
    {
      "label": "Package donut-vscode",
      "type": "shell",
      "command": "npx vsce package",
      "options": {
        "cwd": "${workspaceFolder}/donut-vscode"
      }
    }
  ]
}
