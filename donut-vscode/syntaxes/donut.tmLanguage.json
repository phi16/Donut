{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Donut",
  "scopeName": "source.donut",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#keyword" },
    { "include": "#operator" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment": {
      "match": "//.*$",
      "name": "comment.line.double-slash.donut"
    },
    "string": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.donut"
    },
    "number": {
      "match": "\\b[0-9]+\\b",
      "name": "constant.numeric.donut"
    },
    "keyword": {
      "match": "\\b(with|where|import|use)\\b",
      "name": "keyword.control.donut"
    },
    "operator": {
      "match": ":=|\\+=|~>|→|->|~|=|:",
      "name": "keyword.operator.donut"
    },
    "punctuation": {
      "match": "[;,.\\[\\](){}]",
      "name": "punctuation.donut"
    }
  }
}
