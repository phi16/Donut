[hsv(0.75, 0.5, 1)]
Fl: b → a
[hsv(0.85, 0.5, 1)]
Fr: a → b
[hsv("1-")]
Fa: Fr Fl → a
[hsv("2-")]
Fb: b → Fl Fr

[hsv(0.8, 0.5, 1)]
Fx : Fl x Fr → y
[hsv(0.8, 0.5, 1)]
Fx': y → Fl x Fr

Fxx : Fx'; Fx → y
Fxx': Fl x Fr → Fx; Fx'

Ff: Fx'; Fl f Fr; Fx → g
Fm: Fx' Fx'; Fl x Fa x Fr; Fl m Fr; Fx → n

xch: Fl (x Fa x; m; f) Fr → Fl x Fa x Fr; Fl m Fr; Fl f Fr

k: Fx' Fx'; Fl (x Fa x; m; f) Fr; Fx → n; g =
  Fx' Fx'; xch; Fx ;;
  Fx' Fx'; Fl x Fa x Fr; Fl m Fr; Fxx'; Fl f Fr; Fx ;;
  Fm; Ff


invertible[C, D]: C → D with {
  inv: D → C,
  c: f <?> inv → D // 書く方法がない (`;5;` 記法が使えるか？)
    // ↑ `;[n];` みたいにして　変数を突っ込めるみたいなの　どう
    // もはやマイナスで数えたほうがいいのかなあこれ
    // ↑ それだと id つけたときに意味が変わっちゃう
    // または Level だけスコープが違う ← でも混乱の元になりそう
  c' = invertible[f, inv, c]
}

