[hsv(0.75, 0.5, 1)]
Fl: b → a
[hsv(0.85, 0.5, 1)]
Fr: a → b
Fa: Fr Fl → a 
Fb: b → Fl Fr

Fx : Fl x Fr → y
Fx': y → Fl x Fr

result = Fx' Fx'; Fl x Fa x Fr; Fl m Fr; Fx

