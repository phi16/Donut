import "ui"

// Parametric monoid
//
// Expected hover labels:
//   0-cells: u
//   1-cells: cat.x[u]
//   2-cells: cat.m[u]
//   3-cell:  cat.a[u] (= result)

cat[C: *] = {
    [style.color[hsv[0.6, 1, 1]]]
    x: C → C
    [style.color[hsv[0.1, 1, 1]]]
    m: x x → x
    [style.color[hsv[0.2, 1, 1]]]
    a: m x; m → x m; m
}

[style.color[gray[80]]]
u: *

c = cat[u]

result = c.a
